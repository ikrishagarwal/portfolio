---
import WorkCard from "@/components/WorkCard.astro";

const workCards = [
  {
    src: "/src/images/technika.png",
    link: "https://github.com/ikrishagarwal/technika-server",
    title: "Technika - The Annual Tech Fest",
    description:
      "Technika is the annual technical fest at BIT where I handled writing the backend for the event's website which in its lifetime handled over 150K+ API calls and catered over 1K users for the fest. This later became the benchmark for upcoming fest website at the college and were built on the same codebase as a base reference.",
    tags: ["typescript", "nodejs", "fastify", "firebase"],
    topics: ["BACKEND", "REST", "API"],
  },
  {
    src: "/src/images/krix.png",
    link: "https://krix.now.sh",
    title: "Krix - A multipurpose Discord bot",
    description:
      "Krix is a versatile Discord Bot designed to enhance server management and user engagement. With features ranging from moderation tools to fun commands, Krix is the perfect addition to any Discord community. Which started as a hobby project now caters over 1 Million users and is a part of some big active servers.",
    tags: ["typescript", "nodejs", "discord.js"],
    topics: ["discord", "bot", "API"],
    private: true,
  },
  {
    src: "/src/images/kwiz.png",
    link: "https://github.com/ikrishagarwal/kwiz",
    title: "Kwiz - A live quiz platform",
    description:
      "Kwiz is a modern quiz website designed to help professors quickly organize live quiz sessions with their students. With a real-time leaderboard and seamless user experience, Kwiz makes learning fun and engaging. Built with a websocket driven real-time layer eliminating lags and any sort of leaks.",
    tags: ["react", "tailwind", "typescript", "nodejs"],
    topics: ["Websockets", "deno", "live", "quiz"],
  },
  {
    src: "/src/images/keeb.png",
    link: "https://github.com/ikrishagarwal/Seed75",
    title: "Seed75 - A handcrafted mechanical keyboard",
    description:
      "A completely hand made 75% mechanical keyboard from PCB to case, even the firmware. Designed using KiCad and built using the KMK firmware framework. After building a macropad, going for a full keyboard is the only right decision.",
    tags: ["QMK", "KMK", "KiCad", "Fusion360"],
    topics: ["keyboard", "CAD", "Electronics", "Hardware"],
  },
  {
    src: "/src/images/silly-swap.png",
    link: "https://github.com/ikrishagarwal/silly-swap",
    title: "Silly Swap - Another swapping algorithm",
    description:
      "Deviced an algorithm to swap two numbers without another using a third variable or any arithmetic or XOR operations. Relying on the shifting of binary numbers and compliments of numbers, this algorithm is as good any other method of swapping values of two variables.",
    tags: ["c", "bitwise", "binary"],
    topics: ["algorithms", "swap", "shifting"],
  },
];
---

<section id="works" class="text-secondary px-12 pt-20 border-b border-gray-border border-t-0 flex-1">
  <h2 id="works-heading" class="text-5xl md:text-8xl font-bold font-brand text-center">
    Notable
    <br class="block md:hidden" />
    Works
  </h2>
  <section class="overflow-x-hidden">
    {
      workCards.map((work, index) => (
        <WorkCard
          src={work.src}
          link={work.link}
          title={work.title}
          description={work.description}
          tags={work.tags}
          index={index}
          isPrivate={work.private}
          topics={work.topics}
        />
      ))
    }
  </section>
  <div class="flex flex-row lg:flex-col items-center mb-14">
    <a href="/works" class="mr-3 lg:mr-0 cursor-vanish">
      <button
        class="cursor-pointer w-full max-w-md px-18 lg:px-24 py-3 bg-secondary text-background font-spline-mono font-bold rounded-xl hover:bg-accent transition-colors"
      >
        See More
      </button>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { SplitText, ScrollTrigger } from "gsap/all";

  const heading = document.getElementById("works-heading");

  gsap.registerPlugin(SplitText, ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: heading,
      start: "top 80%",
    },
  });

  const split = new SplitText(heading, {
    type: "chars",
  });
  tl.fromTo(
    split.chars,
    { x: -20, opacity: 0 },
    {
      duration: 1,
      x: 0,
      opacity: 1,
      stagger: 0.05,
      ease: "back.out",
    },
  );

  // Animating the cards
  gsap.set(".work-card", { scale: 0.9 });

  // create a ScrollTrigger for each card
  (gsap.utils.toArray(".work-card") as Element[]).forEach((card, i) => {
    gsap
      .timeline({
        scrollTrigger: {
          trigger: card,
          start: "top 80%",
          once: true,
        },
      })
      .fromTo(
        card,
        { x: i & 1 ? -300 : 300, opacity: 0 },
        {
          duration: 0.75,
          x: 0,
          opacity: 1,
          stagger: 0.5,
          ease: "power2.out",
        },
      )
      .to(
        card,
        {
          scale: 1,
          stagger: 0.5,
          ease: "back.out(1.7)",
        },
        "<0.75",
      );

    if (window.matchMedia && window.matchMedia("(pointer: coarse)").matches) return;
  });
</script>
