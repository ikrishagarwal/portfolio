---
import Time from "@/components/Time.astro";
---

<header id="navbar" class="flex text-secondary border-b border-b-gray-border px-6 py-6 items-center sticky z-60">
  <div class="text-xl flex-1 md:flex-none cursor-pointer cursor-vanish font-spline-mono" id="name-trigger">
    krish{" "}
    <span id="name-animated" class="hidden md:inline opacity-0 absolute text-accent"> agarwal </span>
  </div>

  <div class="flex-1 hidden md:block">
    <nav class="flex justify-center gap-4 font-spline-mono uppercase">
      <a href="/" class="nav-links cursor-vanish">
        <span class="nav-text">Home</span>
        <span class="nav-underline"></span>
      </a>
      <a href="/works" class="nav-links cursor-vanish">
        <span class="nav-text">Works</span>
        <span class="nav-underline"></span>
      </a>
      <a href="/blogs" class="nav-links cursor-vanish">
        <span class="nav-text">Blogs</span>
        <span class="nav-underline"></span>
      </a>
    </nav>
  </div>

  <div class="flex items-center gap-4">
    <div class="font-spline-mono text-gray-400 hidden md:block lg:order-3">
      <Time />
    </div>
    <button
      id="hamburger-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer cursor-vanish"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span id="hl-1" class="hamburger-line"></span>
      <span id="hl-2" class="hamburger-line"></span>
      <span id="hl-3" class="hamburger-line"></span>
    </button>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 lg:hidden bg-background/95 backdrop-blur-sm"
  aria-hidden="true"
>
  <nav class="flex flex-col items-center justify-center h-full gap-8">
    <a href="/" class="mobile-nav-link text-2xl font-spline-mono uppercase text-secondary cursor-vanish">Home</a>
    <a href="/works" class="mobile-nav-link text-2xl font-spline-mono uppercase text-secondary cursor-vanish">Works</a>
    <a href="/blogs" class="mobile-nav-link text-2xl font-spline-mono uppercase text-secondary cursor-vanish">Blogs</a>
  </nav>
</div>

<script>
  import gsap from "gsap";
  import { ScrambleTextPlugin } from "gsap/all";

  const nav = document.getElementById("navbar");
  const nameTrigger = document.getElementById("name-trigger");
  const nameAnimated = document.getElementById("name-animated");
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");
  const hamburgerLines = [
    document.getElementById("hl-1"),
    document.getElementById("hl-2"),
    document.getElementById("hl-3"),
  ];

  gsap.registerPlugin(ScrambleTextPlugin);

  const navbarTl = gsap.timeline();

  navbarTl.fromTo(
    nav,
    {
      y: -100,
      opacity: 0,
      scaleX: 0.95,
      scaleY: 0.8,
      borderRadius: "8px",
      borderTop: "1px solid #444444",
      borderLeft: "1px solid #444444",
      borderRight: "1px solid #444444",
    },
    { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" },
    "navSlide",
  );

  navbarTl.to(nav, {
    scaleX: 1,
    scaleY: 1,
    borderRadius: "0px",
    borderTop: "none",
    borderLeft: "none",
    borderRight: "none",
    duration: 0.75,
    ease: "power2.out",
  });

  // Hamburger entrance animation (mobile only)
  navbarTl.fromTo(
    hamburgerBtn,
    { y: -100, opacity: 0, scale: 0.8 },
    { y: 0, opacity: 1, scale: 1, duration: 0.5, ease: "power2.out" },
    "navSlide",
  );

  // Name scramble animation
  let nameAnimation: gsap.core.Tween | null = null;

  const animateName = () => {
    if (nameAnimation) nameAnimation.kill();

    nameAnimation = gsap.to(nameAnimated, {
      opacity: 0.9,
      duration: 1.5,
      ease: "power2.out",
      scrambleText: {
        text: "agarwal",
        chars: "01",
        speed: 0.3,
      },
    });
  };

  const revertName = () => {
    if (nameAnimation) nameAnimation.kill();

    gsap.to(nameAnimated, {
      opacity: 0,
      duration: 0.2,
      ease: "power2.out",
      onComplete: () => {
        gsap.set(nameAnimated, { opacity: 0 });
      },
    });
  };

  nameTrigger!.addEventListener("mouseenter", animateName);
  nameTrigger!.addEventListener("mouseleave", revertName);

  // Nav link hover animations (desktop only - ≥768px)
  const navLinks = document.querySelectorAll(".nav-links") as NodeListOf<Element & { tl: gsap.core.Timeline }>;
  const navUnderlines = document.querySelectorAll(".nav-underline");
  const navTexts = document.querySelectorAll(".nav-text");

  const mediaQuery = window.matchMedia("(min-width: 768px)");

  const handleMouseEnter = (link: typeof navLinks[0]) => link.tl.tweenFromTo(0, "midway");
  const handleMouseLeave = (link: typeof navLinks[0]) => link.tl.play();

  const updateHoverListeners = (isDesktop: boolean) => {
    navLinks.forEach((link, i) => {
      // Remove existing listeners
      link.removeEventListener("mouseenter", () => handleMouseEnter(link));
      link.removeEventListener("mouseleave", () => handleMouseLeave(link));
      
      if (isDesktop) {
        link.addEventListener("mouseenter", () => handleMouseEnter(link));
        link.addEventListener("mouseleave", () => handleMouseLeave(link));
      }
    });
  };

  // Initial setup
  updateHoverListeners(mediaQuery.matches);

  // Update on resize
  mediaQuery.addEventListener("change", (e) => updateHoverListeners(e.matches));

  navLinks.forEach((link, i) => {
    const underline = navUnderlines[i];
    const navText = navTexts[i];

    const tl = gsap.timeline({ paused: true });

    if (underline) {
      tl.add("start");

      tl.fromTo(underline, { width: "0%", left: "0%" }, { width: "100%", duration: 0.5 });

      tl.to(
        navText,
        {
          scrambleText: {
            text: navText.textContent || "",
            chars: "01",
          },
          duration: 0.8,
          ease: "power2.out",
        },
        "start",
      );

      tl.add("midway");

      tl.fromTo(
        underline,
        { width: "100%", left: "0%" },
        {
          width: "0%",
          left: "100%",
          duration: 0.5,
          immediateRender: false,
        },
      );
    }

    link.tl = tl;
  });

  // Mobile hamburger menu
  let menuOpen = false;
  let menuTimeline: gsap.core.Timeline | null = null;

  // Set initial state for mobile menu (off-screen right)
  gsap.set(mobileMenu, { xPercent: 100 });

  // Set transform origin for hamburger lines rotation
  hamburgerLines.forEach((line) => {
    if (line) gsap.set(line, { transformOrigin: "center center" });
  });

  const createMenuTimeline = () => {
    const tl = gsap.timeline({ paused: true });

    // Sidebar slides in from right
    tl.fromTo(mobileMenu, { xPercent: 100 }, { xPercent: 0, duration: 0.7, ease: "power4.inOut" });

    // Hamburger to cross animation
    tl.to(hamburgerLines[0], { rotation: 45, y: 8, duration: 0.3, ease: "power2.inOut" }, "<");
    tl.to(hamburgerLines[1], { opacity: 0, scaleX: 0, duration: 0.2, ease: "power2.inOut" }, "<");
    tl.to(hamburgerLines[2], { rotation: -45, y: -8, duration: 0.3, ease: "power2.inOut" }, "<");

    // Nav links stagger in
    tl.fromTo(
      mobileNavLinks,
      { x: 80, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.6, stagger: 0.1, ease: "power3.out" },
      "-=0.4",
    );

    return tl;
  };

  const openMenu = () => {
    if (!menuTimeline) {
      menuTimeline = createMenuTimeline();
    }
    menuTimeline.play();
    menuOpen = true;
    hamburgerBtn?.setAttribute("aria-expanded", "true");
    mobileMenu?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    if (menuTimeline) {
      menuTimeline.reverse();
    }
    menuOpen = false;
    hamburgerBtn?.setAttribute("aria-expanded", "false");
    mobileMenu?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  const toggleMenu = () => {
    if (menuOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  };

  hamburgerBtn?.addEventListener("click", toggleMenu);

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close menu on escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) {
      closeMenu();
    }
  });
</script>
