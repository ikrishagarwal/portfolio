---
import "@/styles/global.css";

interface Props {
  title?: string;
}
const { title = "Krish | Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/brockmann.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-image">
    <slot />
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "c539d7f820d04d21a853f0b6bd7e7d7a"}'
    ></script>
  </body>
</html>
