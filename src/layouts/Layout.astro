---
import SEO from "@/components/SEO.astro";
import NavBar from "@/sections/NavBar.astro";
import Footer from "@/components/Footer.astro";
import CursorFollower from "@/components/CursorFollower.astro";
import "@/styles/global.css";

interface Props {
  title?: string;
  windowTitle?: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: string;
  enableSmoothScroll?: boolean;
  enableCursor?: boolean;
}

const {
  title = "Krish — Full-Stack Developer & Open Source Enthusiast",
  windowTitle = "Krish | Portfolio",
  description = "Portfolio of Krish, who is a passionate full-stack software developer specializing in TypeScript, React, and Node.js. Explore projects ranging from Discord bots to mechanical keyboards and open-source contributions.",
  keywords = "Krish Agarwal, portfolio, software developer, full-stack developer, web developer, TypeScript, React, Node.js, open source, Discord bot, mechanical keyboard, QMK, KiCad, ikrishagarwal",
  image = "/images/hero.png",
  type = "website",
  enableSmoothScroll = true,
  enableCursor = false,
} = Astro.props;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : new URL(Astro.url.pathname, Astro.url.origin);
const imageURL = Astro.site ? new URL(image, Astro.site) : new URL(image, Astro.url.origin);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Krish Agarwal",
  url: "https://www.ikrish.dev",
  jobTitle: "Full-Stack Developer",
  description:
    "Full-stack developer specializing in TypeScript, React, and Node.js. Open source enthusiast and mechanical keyboard hobbyist.",
  sameAs: ["https://github.com/ikrishagarwal", "https://www.linkedin.com/in/ikrishagarwal"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      windowTitle={windowTitle}
      description={description}
      keywords={keywords}
      canonicalUrl={canonicalURL.toString()}
      imageUrl={imageURL.toString()}
      type={type}
      jsonLd={jsonLd}
    />

    <link rel="preload" href="/fonts/brockmann.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-image" data-smooth-scroll-enabled={enableSmoothScroll}>
    {enableCursor && <CursorFollower />}
    <NavBar />
    <slot />
    <Footer />
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "c539d7f820d04d21a853f0b6bd7e7d7a"}'></script>
  </body><script>
    import Lenis from "lenis";
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/all";

    if (document.body.dataset.smoothScrollEnabled === "true") {
      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        autoRaf: false,
        wheelMultiplier: 0.5,
        lerp: 0.05,
      });

      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);
    }
  </script>
</html>
