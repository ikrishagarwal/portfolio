---
import NavBar from "@/sections/NavBar.astro";
import Footer from "@/components/Footer.astro";
import StyledDate from "@/components/date.astro";
import SEO from "@/components/SEO.astro";
import type { CollectionEntry } from "astro:content";
import { getImage, Image } from "astro:assets";

import "@/styles/global.css";

type Props = CollectionEntry<"blog">["data"];
const { description, coverImage, createdAt, updatedAt, tags } = Astro.props;

const heading = Astro.props.title;
const title = `${heading} | Krish`;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;

const ogImage = coverImage ? await getImage({ src: coverImage, width: 1200, height: 630, format: "jpg" }) : undefined;
const ogImageUrl = ogImage?.src && Astro.site ? new URL(ogImage.src, Astro.site).toString() : undefined;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: ogImageUrl,
  datePublished: createdAt.toISOString(),
  dateModified: updatedAt.toISOString(),
  author: {
    "@type": "Person",
    name: "Krish Agarwal",
    url: "https://ikrish.dev",
  },
  publisher: {
    "@type": "Person",
    name: "Krish Agarwal",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  keywords: tags?.join(", "),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://ikrish.dev" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://ikrish.dev/blogs/" },
    { "@type": "ListItem", position: 3, name: title, item: canonicalUrl },
  ],
};
---

<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      keywords={tags?.join(" ")}
      canonicalUrl={canonicalUrl}
      imageUrl={ogImageUrl}
      type="article"
      jsonLd={[articleJsonLd, breadcrumbJsonLd]}
    />

    <meta property="article:published_time" content={createdAt.toISOString()} />
    <meta property="article:modified_time" content={updatedAt.toISOString()} />
    {tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <link rel="preload" href="/fonts/brockmann.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-image">
    <NavBar />
    <section class="flex justify-center w-full min-h-screen h-full py-2 m-0 mt-2 blogpost">
      <article class="max-w-4xl w-full bg-background-light text-stone-50 rounded">
        {
          coverImage && (
            <Image
              src={coverImage}
              alt={`Cover for ${heading}`}
              class="w-full h-64 object-top-left object-cover rounded-t"
              loading="eager"
            />
          )
        }
        <div class="p-10">
          <header>
            <div class="text-gray-400 my-3 font-mono">
              <a href="/blogs/" class="md:hover:underline">[Back to Home]</a>
            </div>
            <h1 class="text-4xl md:text-5xl font-brand font-semibold text-secondary">{heading}</h1>
            <p class="my-2">
              <span class="text-gray-600 font-mono">Updated At <StyledDate date={updatedAt} /></span>
            </p>
            <div class="my-2 font-spline-mono flex flex-wrap">
              {
                tags?.map((tag) => (
                  <span class="text-sm font-spline-mono px-2 mr-2 my-1 rounded-full border border-gray-600/50 text-gray-400">
                    {tag}
                  </span>
                ))
              }
            </div>
          </header>

          <div class="my-10 text-lg">
            <slot />
          </div>
        </div>
      </article>
    </section>
    <Footer />
    <script is:inline>
  const CLIPBOARD_SVG = `<svg width="24" height="24" viewBox="0 0 24 24" stroke-width="1.5" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.5 4H6C4.89543 4 4 4.89543 4 6V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V6C20 4.89543 19.1046 4 18 4H15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M8 6.4V4.5C8 4.22386 8.22386 4 8.5 4C8.77614 4 9.00422 3.77604 9.05152 3.50398C9.19968 2.65171 9.77399 1 12 1C14.226 1 14.8003 2.65171 14.9485 3.50398C14.9958 3.77604 15.2239 4 15.5 4C15.7761 4 16 4.22386 16 4.5V6.4C16 6.73137 15.7314 7 15.4 7H8.6C8.26863 7 8 6.73137 8 6.4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg>`;

  const CHECK_SVG = `<svg width="24" height="24" viewBox="0 0 24 24" stroke-width="1.5" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.5 4H6C4.89543 4 4 4.89543 4 6V20C4 21.1046 4.89543 22 6 22H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M15.5 4H18C19.1046 4 20 4.89543 20 6V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M8 6.4V4.5C8 4.22386 8.22386 4 8.5 4C8.77614 4 9.00422 3.77604 9.05152 3.50398C9.19968 2.65171 9.77399 1 12 1C14.226 1 14.8003 2.65171 14.9485 3.50398C14.9958 3.77604 15.2239 4 15.5 4C15.7761 4 16 4.22386 16 4.5V6.4C16 6.73137 15.7314 7 15.4 7H8.6C8.26863 7 8 6.73137 8 6.4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M15.5 20.5L17.5 22.5L22.5 17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;

  document.querySelectorAll('pre.astro-code').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code');
    btn.setAttribute('tabindex', '0');
    btn.innerHTML = CLIPBOARD_SVG;
    pre.appendChild(btn);

    const copy = async () => {
      const code = pre.querySelector('code')?.textContent || pre.textContent;
      try {
        await navigator.clipboard.writeText(code);
        btn.classList.add('copied');
        btn.innerHTML = CHECK_SVG;
        btn.setAttribute('aria-label', 'Copied!');
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.innerHTML = CLIPBOARD_SVG;
          btn.setAttribute('aria-label', 'Copy code');
        }, 2000);
      } catch (e) {
        console.warn('Copy failed:', e);
      }
    };

    btn.addEventListener('click', copy);
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        copy();
      }
    });
  });
</script>
  </body>
</html>
