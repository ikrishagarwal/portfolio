        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://github.com/ikrishagarwal"
            class="block cursor-vanish footer-link"
            target="_blank"
            rel="noopener"
          >
            <span class="footer-link-bg"></span>
            <span class="px-2">Github</span>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://www.linkedin.com/in/ikrishagarwal"
            class="block cursor-vanish footer-link"
            target="_blank"
            rel="noopener"
          >
            <span class="footer-link-bg"></span>
            <span class="px-2">LinkedIn</span>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://www.instagram.com/coffee.to.code.machine"
            class="block cursor-vanish footer-link"
            target="_blank"
            rel="noopener"
          >
            <span class="footer-link-bg"></span>
