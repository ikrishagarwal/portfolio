      <a href="/tos" class="underline cursor-vanish">Terms Of Service</a>
      <span> | </span>
      <a href="/privacy-policy" class="underline cursor-vanish">Privacy Policy</a>
    </p>
  </div>
</footer>

<script>
  import gsap from "gsap";

  const mediaQuery = window.matchMedia("(min-width: 768px)");

  const setupFooterLinks = (isDesktop: boolean) => {
    document.querySelectorAll(".footer-link").forEach((link) => {
      const bg = link.querySelector(".footer-link-bg");
      const marker = link.parentElement?.querySelector(".footer-marker");
      const tl = gsap.timeline({ paused: true });

      tl.to(bg, {
        scaleY: 1,
        duration: 0.3,
        ease: "power2.out",
      });

      if (marker) {
        tl.to(
          marker,
          {
            scale: 1.2,
            rotation: 45,
            duration: 0.3,
            ease: "power2.out",
          },
          "<",
        );
      }

      tl.fromTo(
        link,
        { color: "var(--color-secondary)" },
        { color: "var(--color-background)", duration: 0.1 },
        "-=0.2",
      );

      // Remove existing listeners
      link.removeEventListener("mouseenter", handleMouseEnter);
      link.removeEventListener("mouseleave", handleMouseLeave);

      if (isDesktop) {
        link.addEventListener("mouseenter", handleMouseEnter);
        link.addEventListener("mouseleave", handleMouseLeave);
      }

      function handleMouseEnter() {
        tl.play();
      }

      function handleMouseLeave() {
        tl.reverse();
      }
    });
  };

  // Initial setup
  setupFooterLinks(mediaQuery.matches);

  // Update on resize
  mediaQuery.addEventListener("change", (e) => setupFooterLinks(e.matches));
</script>
