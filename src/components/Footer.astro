          </a>
        </div>
      </div>
    </div>
    <div>
      <div class="font-brand uppercase text-secondary text-lg lg:text-xl font-medium">
        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://patreon.com/ikrishagarwal?utm_medium=portfolio"
            class="block cursor-vanish footer-link"
            target="_blank"
            rel="noopener"
          >
            <span class="footer-link-bg"></span>
            <span class="px-2">Patreon</span>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://ko-fi.com/ikrishagarwal"
            class="block cursor-vanish footer-link"
            target="_blank"
            rel="noopener"
          >
            <span class="footer-link-bg"></span>
            <span class="px-2">Ko-Fi</span>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span class="footer-marker">
            <FooterMarker />
          </span>
          <a
            href="https://github.com/sponsors/ikrishagarwal"
            class="block cursor-vanish footer-link"
